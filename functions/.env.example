# Kopie nach .env und Werte eintragen. .env wird beim Deploy geladen und ist in .gitignore.

# Einladungs-E-Mail: Secret (muss mit Next.js .env.local übereinstimmen)
INVITATION_EMAIL_SECRET=

# Einladungs-E-Mails: Resend (empfohlen) oder SMTP
# Resend: API-Key von https://resend.com/api-keys, optional RESEND_FROM=JobFlow <noreply@domain.de>
RESEND_API_KEY=
# RESEND_FROM=JobFlow <noreply@ihredomain.de>
# Oder SMTP (für Einladungen über Firebase Function):
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=JobFlow <noreply@ihredomain.de>
