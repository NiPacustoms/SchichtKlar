rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public company logos (uploaded by authenticated admins)
    match /logos/{allPaths=**} {
      // Read: allow public read to display logo in app
      allow read: if true;
      // Write: nur Admins (Firmenlogo ist eine administrative Einstellung);
      // zusätzlich auf Bild-Typen und Größe begrenzt.
      allow write: if request.auth != null &&
        request.auth.token.role == 'admin' &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
      // Delete: only admins
      allow delete: if request.auth != null && request.auth.token.role == 'admin';
    }

    // Documents Storage Path: /documents/{userId}/{documentId}/{fileName}
    match /documents/{userId}/{documentId}/{fileName} {
      // Read: Own documents OR admin
      allow read: if request.auth != null && 
        (request.auth.uid == userId || request.auth.token.role == 'admin');
      
      // Write: Own documents only, with size and type restrictions
      allow write: if request.auth != null && 
        request.auth.uid == userId &&
        request.resource.size < 10 * 1024 * 1024 &&  // Max 10MB
        request.resource.contentType.matches('image/.*|application/pdf');
      
      // Delete: Own documents OR admin
      allow delete: if request.auth != null &&
        (request.auth.uid == userId || request.auth.token.role == 'admin');
    }

    // Chat-Anhänge: /messages/{channelId}/{fileName}
    // Zugriff nur für Teilnehmer des Channels (Cross-Service-Lookup nach Firestore).
    match /messages/{channelId}/{fileName} {
      allow read: if request.auth != null &&
        request.auth.uid in
          firestore.get(/databases/(default)/documents/channels/$(channelId)).data.participants;
      allow write: if request.auth != null &&
        request.auth.uid in
          firestore.get(/databases/(default)/documents/channels/$(channelId)).data.participants &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*|application/pdf|application/vnd.*|text/plain');
      allow delete: if request.auth != null &&
        (request.auth.token.role == 'admin' ||
          request.auth.uid in
            firestore.get(/databases/(default)/documents/channels/$(channelId)).data.participants);
    }

  }
}

