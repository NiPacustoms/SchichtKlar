{
  "name": "jobflow",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20"
  },
  "scripts": {
    "dev": "npx next dev -p 3000",
    "dev:turbo": "npx next dev -p 3000",
    "dev:fix": "node scripts/fix-manifest.js",
    "dev:auto": "node scripts/dev-server.js",
    "dev:kill": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true",
    "dev:clean": "npm run dev:kill && rm -rf .next && npm run dev",
    "dev:reset": "./scripts/setup-dev.sh",
    "cleanup:worktrees": "./scripts/cleanup-worktrees.sh",
    "git:deployed-commit": "./scripts/get-deployed-commit.sh",
    "git:checkout-deployed": "CHECKOUT=1 ./scripts/get-deployed-commit.sh",
    "deps:reinstall": "rm -rf node_modules package-lock.json && npm install",
    "deps:fix-enotempty": "node scripts/remove-npm-temp-dirs.js && npm install",
    "deps:clean": "bash scripts/clean-node-modules.sh",
    "build": "next build",
    "deploy": "npm run build && firebase deploy",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:ci": "eslint . --quiet --rule '@typescript-eslint/no-explicit-any:off' --rule 'react/no-unescaped-entities:off' --rule 'no-empty:off' --rule 'react/jsx-key:off' --rule 'no-unreachable:off' --rule 'no-useless-escape:off'",
    "typecheck": "tsc --noEmit",
    "typecheck:ci": "tsc --noEmit || echo 'Type errors ignored in CI'",
    "validate": "npm run lint && npm run typecheck",
    "ci:verify": "npm run lint:ci && npm run typecheck:ci && node scripts/static-scan.js",
    "format": "prettier --write .",
    "seed": "node scripts/seed-firestore.js",
    "seed:dev": "NODE_ENV=development node scripts/seed-firestore.js",
    "cleanup:demo": "node scripts/cleanup-demo-data.js",
    "firebase:setup": "./scripts/setup-service-account.sh",
    "firebase:verify": "./scripts/verify-service-account.sh",
    "firebase:setup:full": "./scripts/auto-setup-firebase.sh",
    "firebase:enable-apis": "./scripts/enable-required-apis.sh",
    "firebase:fix-permissions": "./scripts/fix-service-account-permissions.sh",
    "firebase:check-status": "./scripts/check-function-status.sh",
    "firebase:wait-deployment": "./scripts/wait-for-deployment.sh",
    "storage:cors": "bash scripts/set-storage-cors.sh",
    "storage:deploy-rules": "firebase deploy --only storage",
    "auto-push": "./scripts/auto-push.sh",
    "auto-push:start": "./scripts/auto-push.sh",
    "replace-console-logs": "node scripts/replace-console-logs-runner.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "coverage": "vitest run --coverage",
    "cleanup:unused-exports": "ts-unused-exports tsconfig.json",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "generate:domain": "node scripts/generate-domain.js"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.4",
    "@mui/material": "^7.3.4",
    "@mui/x-date-pickers": "^8.14.1",
    "@react-pdf/renderer": "^3.4.0",
    "@sentry/nextjs": "^8.30.0",
    "@tanstack/react-query": "^5.90.5",
    "@types/crypto-js": "^4.2.2",
    "@types/jspdf": "^1.3.3",
    "@types/lodash": "^4.17.20",
    "@types/react-dom": "^19.0.0",
    "baseline-browser-mapping": "^2.9.19",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "firebase-admin": "^12.7.0",
    "html2canvas": "^1.4.1",
    "isomorphic-dompurify": "^2.11.0",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.2",
    "lodash": "^4.17.21",
    "nanoid": "^5.1.6",
    "next": "15.5.12",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.65.0",
    "recharts": "^3.3.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/nextjs": "^8.4.0",
    "@storybook/react": "^8.4.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/d3-array": "^3.2.2",
    "@types/d3-color": "^3.1.3",
    "@types/d3-ease": "^3.0.2",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-path": "^3.1.1",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.7",
    "@types/d3-time": "^3.0.4",
    "@types/d3-timer": "^3.0.2",
    "@types/estree": "^1.0.8",
    "@types/json-schema": "^7.0.15",
    "@types/json5": "^0.0.30",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/parse-json": "^4.0.2",
    "@types/prop-types": "^15.7.15",
    "@types/react": "19.2.14",
    "@types/react-transition-group": "^4.4.12",
    "@types/recharts": "^1.8.29",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^2.1.0",
    "autoprefixer": "^10.4.22",
    "dotenv": "^17.2.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.12",
    "eslint-config-prettier": "^9.1.0",
    "firebase": "^12.6.0",
    "prettier": "^3.8.1",
    "source-map-js": "^1.2.1",
    "storybook": "^8.4.0",
    "tailwindcss": "^4.1.17",
    "typescript": "5.9.3",
    "vitest": "^2.1.0"
  },
  "overrides": {
    "@eslint/eslintrc": "2.1.4",
    "rimraf": "^4",
    "glob": "^10"
  }
}
