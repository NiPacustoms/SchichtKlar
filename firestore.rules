rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      // Custom Claims – primäre Quelle für Berechtigungen
      return isAuthenticated() &&
             request.auth.token.role != null &&
             request.auth.token.role == role;
    }

    // Fallback: Rolle aus User-Dokument, wenn Custom Claims noch nicht gesetzt (z. B. vor Sync)
    function hasRoleFromUserDoc(role) {
      let doc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isAuthenticated() && doc != null && doc.data.role == role;
    }

    function isAdmin() {
      return isAuthenticated() && (hasRole('admin') || hasRoleFromUserDoc('admin'));
    }

    // ── Mandantenisolation (echt, Multi-Tenant) ────────────────────────────
    // CompanyId des Requestors: primär aus dem Custom-Claim (billig, kein
    // Dokument-Read), Fallback auf das User-Dokument, solange der Claim (z. B.
    // vor dem Backfill/Token-Refresh) noch nicht gesetzt ist. Der Fallback-get()
    // wird dank Kurzschluss nur ausgewertet, wenn der Claim fehlt.
    function requesterCompanyIdFromUserDoc() {
      let doc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return (doc != null && doc.data != null) ? doc.data.companyId : null;
    }

    function getRequesterCompanyId() {
      return isAuthenticated()
        ? (request.auth.token.companyId != null
            ? request.auth.token.companyId
            : requesterCompanyIdFromUserDoc())
        : null;
    }

    // Für Aggregations-/List-Queries: der Requestor muss überhaupt einem
    // Unternehmen zugeordnet sein. Die Dokument-Regeln filtern pro Dokument.
    function hasCompanyContext() {
      return getRequesterCompanyId() != null;
    }

    // Prüft, ob das Dokument zur gleichen Company gehört wie der Requestor.
    // Legacy-Dokumente ohne companyId (null) werden zur Migration toleriert.
    function belongsToSameCompany(resourceCompanyId) {
      return resourceCompanyId == null || resourceCompanyId == getRequesterCompanyId();
    }

    // Prüft, ob ein zu schreibendes Dokument der eigenen Company zugeordnet wird.
    // Ein fehlender (null) Wert wird toleriert (serverseitig/Legacy), ein
    // GESETZTER Wert muss der eigenen Company entsprechen (kein Fremd-Tenant).
    function creatingForSameCompany(requestCompanyId) {
      return requestCompanyId == null || requestCompanyId == getRequesterCompanyId();
    }

    // Users: Jede Mitarbeiter-Rolle ist von anderen getrennt – nur eigene Daten lesbar.
    // Nur Admin hat volle Kontrolle (alle User derselben Company lesen/schreiben).
    // WICHTIG: Eigene Dokumente können IMMER gelesen werden (Henne-Ei beim ersten Login).

    // Sicherheitskritisch: Ein User darf beim Bearbeiten des EIGENEN Dokuments keine
    // rechte-relevanten Felder verändern. Sonst könnte eine Pflegekraft ihr eigenes
    // users-Dokument auf role='admin' setzen und würde über den Rules-Fallback
    // hasRoleFromUserDoc('admin') zum Administrator (Privilege Escalation).
    function selfUpdateKeepsPrivilegedFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'companyId', 'customRoleId']);
    }

    match /users/{uid} {
      // Lesen: Nur eigenes Dokument ODER Admin derselben Company (Mitarbeiter sehen keine anderen Mitarbeiter)
      allow read: if isAuthenticated() && (
        request.auth.uid == uid ||
        (isAdmin() && belongsToSameCompany(resource.data.companyId))
      );
      // Erstellen: Eigene Dokumente ODER Admin derselben Company.
      // Selbst-Anlage darf sich nicht selbst zum Admin machen: role muss fehlen oder 'nurse' sein.
      allow create: if isAuthenticated() && (
        (request.auth.uid == uid &&
         (!('role' in request.resource.data) || request.resource.data.role == 'nurse')) ||
        (hasRole('admin') && creatingForSameCompany(request.resource.data.companyId))
      );
      // Aktualisieren: Eigenes Dokument (ohne Änderung rechte-relevanter Felder)
      // ODER Admin derselben Company (darf Rollen vergeben).
      allow update: if isAuthenticated() && (
        (request.auth.uid == uid && selfUpdateKeepsPrivilegedFields()) ||
        (hasRole('admin') && belongsToSameCompany(resource.data.companyId) &&
         creatingForSameCompany(request.resource.data.companyId))
      );
      // Löschen: Nur Admin derselben Company
      allow delete: if hasRole('admin') && belongsToSameCompany(resource.data.companyId);
    }

    // Users Collection-Level Queries: list erlaubt Abfragen; Document-Rules filtern pro Dokument.
    // Nurse: erhält nur das eigene Dokument. Admin: alle User derselben Company.
    match /users {
      allow list: if hasCompanyContext();
    }

    // Facilities: Lesen für Admin; Schreiben nur Admin mit Mandantenisolation
    match /facilities/{facilityId} {
      allow read: if isAuthenticated() && belongsToSameCompany(resource.data.companyId);
      allow create: if isAdmin() && creatingForSameCompany(request.resource.data.companyId);
      allow update: if isAdmin() && belongsToSameCompany(resource.data.companyId) && 
        creatingForSameCompany(request.resource.data.companyId);
      allow delete: if isAdmin() && belongsToSameCompany(resource.data.companyId);
    }
    
    // Facilities Collection-Level Queries
    // WICHTIG: Collection-Queries müssen client-seitig nach companyId filtern
    match /facilities {
      allow list: if hasCompanyContext();
    }

    // Shifts: Lesen nur innerhalb der eigenen Company; Schreiben nur Admin mit Mandantenisolation
    match /shifts/{shiftId} {
      allow read: if isAuthenticated() && belongsToSameCompany(resource.data.companyId);
      allow create: if isAdmin() && (
        request.resource.data.companyId == null ||
        creatingForSameCompany(request.resource.data.companyId)
      );
      allow update: if isAdmin() && (
        resource.data.companyId == null ||
        (belongsToSameCompany(resource.data.companyId) && 
         (request.resource.data.companyId == null || creatingForSameCompany(request.resource.data.companyId)))
      );
      allow delete: if isAdmin() && (
        resource.data.companyId == null ||
        belongsToSameCompany(resource.data.companyId)
      );
    }
    

    // Documents: Besitzer oder Admin; Schreiben nur Besitzer oder Admin mit Mandantenisolation
    match /documents/{docId} {
      allow read: if isAuthenticated() && belongsToSameCompany(resource.data.companyId) && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated() && creatingForSameCompany(request.resource.data.companyId) && (
        request.resource.data.userId == request.auth.uid || isAdmin()
      );
      allow update: if isAuthenticated() && belongsToSameCompany(resource.data.companyId) && 
        creatingForSameCompany(request.resource.data.companyId) && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAuthenticated() && belongsToSameCompany(resource.data.companyId) && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    // Assignments: Lesen Besitzer/Admin; Schreiben Admin mit Mandantenisolation
    match /assignments/{assignmentId} {
      allow read: if isAuthenticated() && belongsToSameCompany(resource.data.companyId) && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAdmin() && creatingForSameCompany(request.resource.data.companyId);
      allow update: if isAuthenticated() && belongsToSameCompany(resource.data.companyId) && (
        isAdmin() ||
        (resource.data.userId == request.auth.uid &&
         request.resource.data.companyId == resource.data.companyId)
      );
      allow delete: if isAdmin() && belongsToSameCompany(resource.data.companyId);
    }
    

    // Reports: Lesen für Besitzer/Admin; Schreiben nur Admin mit Mandantenisolation
    match /reports/{reportId} {
      allow read: if isAuthenticated() && belongsToSameCompany(resource.data.companyId) && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated() && creatingForSameCompany(request.resource.data.companyId) && (
        request.resource.data.userId == request.auth.uid || isAdmin()
      );
      allow update, delete: if isAdmin() && belongsToSameCompany(resource.data.companyId) && 
        creatingForSameCompany(request.resource.data.companyId);
    }
    

    // Employee Reports: Mitarbeiter-Berichte mit Mandantenisolation
    match /employeeReports/{reportId} {
      allow read: if isAuthenticated() && belongsToSameCompany(resource.data.companyId) && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated() && creatingForSameCompany(request.resource.data.companyId) && (
        request.resource.data.userId == request.auth.uid || isAdmin()
      );
      allow update, delete: if isAdmin() && belongsToSameCompany(resource.data.companyId) && 
        creatingForSameCompany(request.resource.data.companyId);
    }
    

    // Admin Announcements: Ankündigungen (mandantengebunden)
    match /adminAnnouncements/{announcementId} {
      allow read: if isAuthenticated() && belongsToSameCompany(resource.data.companyId);
      allow create: if isAdmin() && creatingForSameCompany(request.resource.data.companyId);
      allow update, delete: if isAdmin() && belongsToSameCompany(resource.data.companyId);
    }

    // Activities: Aktivitäts-Log mit Mandantenisolation
    match /activities/{activityId} {
      allow read: if isAdmin() && belongsToSameCompany(resource.data.companyId);
      allow create: if isAuthenticated() && creatingForSameCompany(request.resource.data.companyId);
      allow update, delete: if isAdmin() && belongsToSameCompany(resource.data.companyId);
    }
    
    // Activities Collection-Level Queries
    // Erlaubt für Admin mit companyId im Token
    match /activities {
      allow list: if isAdmin() && hasCompanyContext();
    }

    // Timesheets: Arbeitszeiterfassung
    // GoBD-konform: approved/submitted Timesheets sind unveränderlich
    // Mit Mandantenisolation
    match /timesheets/{timesheetId} {
      allow read: if isAuthenticated() && (
        // Eigene Timesheets: userId muss übereinstimmen
        resource.data.userId == request.auth.uid ||
        // Admin: Muss zur gleichen Company gehören (wenn companyId vorhanden)
        (isAdmin() && (
          resource.data.companyId == null ||
          belongsToSameCompany(resource.data.companyId)
        ))
      );
      allow create: if isAuthenticated() && (
        request.resource.data.companyId == null || 
        creatingForSameCompany(request.resource.data.companyId)
      );
      
      // Update: Nur wenn NICHT approved/submitted (GoBD-Konformität) und gleiche Company
      allow update: if isAuthenticated() && (
        resource.data.companyId == null || 
        (belongsToSameCompany(resource.data.companyId) && 
         creatingForSameCompany(request.resource.data.companyId))
      ) && (
        resource.data.userId == request.auth.uid || isAdmin()
      ) && (
        resource.data.status != 'approved' && 
        resource.data.status != 'submitted'
      );
      
      // Delete: Nur wenn NICHT approved/submitted (GoBD-Konformität) und gleiche Company
      allow delete: if isAuthenticated() && (
        resource.data.companyId == null || 
        belongsToSameCompany(resource.data.companyId)
      ) && (
        resource.data.userId == request.auth.uid || isAdmin()
      ) && (
        resource.data.status != 'approved' && 
        resource.data.status != 'submitted'
      );
    }
    

    // Wochenstunden-Limit: Anträge auf Erhöhung (Pflegekraft → Admin), mandantengebunden
    match /limitIncreaseRequests/{requestId} {
      allow read: if isAuthenticated() && belongsToSameCompany(resource.data.companyId) && (
        resource.data.mitarbeiterId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated() &&
        request.resource.data.mitarbeiterId == request.auth.uid &&
        creatingForSameCompany(request.resource.data.companyId);
      allow update, delete: if isAdmin() && belongsToSameCompany(resource.data.companyId);
    }

    // Times: Zeiterfassung (Arbeitszeiten, Pausen, Krankheit)
    // WICHTIG: work/break müssen immer an einen zugewiesenen Auftrag (assignmentId) gebunden sein
    // sick kann ohne assignmentId sein
    // HINWEIS: companyId-Feld wurde hinzugefügt für vollständige Mandantenisolation
    // Migration: Alte Einträge ohne companyId werden weiterhin unterstützt (null-Wert)
    match /times/{timeId} {
      // Helper-Funktion: Prüft, ob assignmentId für work/break vorhanden ist
      function hasRequiredAssignment() {
        let entryType = request.resource.data.type;
        // work und break benötigen assignmentId
        return (entryType == 'work' || entryType == 'break') 
          ? request.resource.data.assignmentId != null
          : true; // sick benötigt kein assignmentId
      }
      
      // Helper-Funktion: Prüft Mandantenisolation
      function timesEntryBelongsToSameCompany() {
        let resourceCompanyId = resource.data.companyId;
        let requestCompanyId = request.resource.data.companyId;
        let authCompanyId = getRequesterCompanyId();
        
        // Wenn companyId im Dokument vorhanden ist, muss es mit Auth übereinstimmen
        // Migration: null-Werte werden akzeptiert (alte Einträge)
        return resourceCompanyId == null || requestCompanyId == null || 
               resourceCompanyId == authCompanyId || requestCompanyId == authCompanyId;
      }
      
      // Lesen: Eigene Time Entries ODER Admin derselben Company
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        (hasRole('admin') && timesEntryBelongsToSameCompany())
      );
      
      // Erstellen: Eigene Time Entries ODER Admin derselben Company
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid || 
        (hasRole('admin') && timesEntryBelongsToSameCompany())
      ) && hasRequiredAssignment() &&
        (request.resource.data.companyId == getRequesterCompanyId() || 
         request.resource.data.companyId == null);
      
      // Aktualisieren: Eigene Time Entries ODER Admin derselben Company
      // WICHTIG: work/break müssen assignmentId behalten, companyId muss erhalten bleiben
      // Für neue Einträge (create) ist assignmentId Pflicht, für Updates erlauben wir auch alte Einträge ohne assignmentId
      // um Migration zu ermöglichen
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        (hasRole('admin') && timesEntryBelongsToSameCompany())
      ) && (
        // Wenn bestehender Typ work/break ist:
        // - Erlaube Update, wenn assignmentId im Update ODER im Dokument vorhanden ist
        // - ODER wenn assignmentId in beiden fehlt/null ist (alte Einträge, Migration)
        (resource.data.type == 'work' || resource.data.type == 'break')
          ? (
            // Wenn assignmentId im Update vorhanden ist (nicht null/undefined)
            (request.resource.data.assignmentId != null) ||
            // ODER wenn assignmentId im bestehenden Dokument vorhanden ist (nicht null/undefined)
            (resource.data.assignmentId != null) ||
            // ODER wenn assignmentId in beiden fehlt/null ist (Migration für alte Einträge)
            // Prüfe explizit auf null oder fehlendes Feld
            (!('assignmentId' in request.resource.data) || request.resource.data.assignmentId == null) &&
            (!('assignmentId' in resource.data) || resource.data.assignmentId == null)
          )
          : true
      ) && (
        // companyId muss erhalten bleiben oder von null auf companyId gesetzt werden (Migration)
        request.resource.data.companyId == resource.data.companyId || 
        (resource.data.companyId == null && request.resource.data.companyId == getRequesterCompanyId())
      );
      
      // Löschen: Eigene Time Entries ODER Admin derselben Company
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        (hasRole('admin') && timesEntryBelongsToSameCompany())
      );
    }
    

    // Alerts: Benachrichtigungen und Warnungen mit Mandantenisolation
    match /alerts/{alertId} {
      allow read: if isAuthenticated() && belongsToSameCompany(resource.data.companyId) && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated() && creatingForSameCompany(request.resource.data.companyId);
      allow update: if isAuthenticated() && belongsToSameCompany(resource.data.companyId) && 
        creatingForSameCompany(request.resource.data.companyId) && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin() && belongsToSameCompany(resource.data.companyId);
    }
    
    // Alerts Collection-Level Queries
    // Erlaubt für alle authentifizierten User mit companyId im Token
    // Die Dokument-Regeln filtern die Ergebnisse automatisch
    match /alerts {
      allow list: if hasCompanyContext();
    }

    // Notifications: Benachrichtigungen mit Mandantenisolation
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && belongsToSameCompany(resource.data.companyId) && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated() && creatingForSameCompany(request.resource.data.companyId);
      allow update: if isAuthenticated() && belongsToSameCompany(resource.data.companyId) && 
        creatingForSameCompany(request.resource.data.companyId) && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAuthenticated() && belongsToSameCompany(resource.data.companyId) && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }
    
    // Notifications Collection-Level Queries
    // WICHTIG: Collection-Queries müssen client-seitig nach companyId filtern
    // Für Aggregation-Queries muss der Benutzer eine companyId im Token haben
    match /notifications {
      allow list: if hasCompanyContext();
    }

    // Settings: System-Einstellungen
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
    
    // Config: Zentrale Konfigurationsdokumente (z.B. Kategorien)
    // Lesen: alle authentifizierten Nutzer
    // Schreiben: nur Admin
    match /config/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Settings Collection-Level Queries
    match /settings {
      allow list: if isAdmin();
    }

    // SystemSettings: System-Einstellungen (alternative Collection)
    match /systemSettings/{settingId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
    
    // SystemSettings Collection-Level Queries
    match /systemSettings {
      allow list: if isAdmin();
    }

    // AdminSettings: Admin-Einstellungen
    match /adminSettings/{settingId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
    
    match /adminSettings {
      allow list: if isAdmin();
    }

    // AdminRoles: Admin-Rollen (Admins verwalten; Nutzer dürfen ihre zugewiesene Rolle lesen)
    function isOwnAssignedRole(roleId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null && userDoc.data != null && userDoc.data.customRoleId == roleId;
    }
    match /adminRoles/{roleId} {
      allow read: if isAdmin() || (isAuthenticated() && isOwnAssignedRole(roleId));
      allow create, update, delete: if isAdmin();
    }
    
    match /adminRoles {
      allow list: if isAdmin();
    }

    // AdminDocumentTypes: Admin-Dokumenttypen
    match /adminDocumentTypes/{docTypeId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
    
    match /adminDocumentTypes {
      allow list: if isAdmin();
    }

    // DocumentTypes: Dokumententypen für alle Benutzer
    match /documentTypes/{docTypeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    

    // Audit Logs: Unveränderlich (GoBD-Konformität)
    // Nur Cloud Functions dürfen schreiben, alle Änderungen sind verboten
    // Mit Mandantenisolation
    match /auditLogs/{logId} {
      allow read: if isAdmin() && belongsToSameCompany(resource.data.companyId);
      allow create: if false; // Nur Cloud Functions können schreiben (bypass Rules)
      allow update, delete: if false; // Unveränderlich nach Erstellung
    }
    
    // Audit Logs Collection-Level Queries
    // WICHTIG: Collection-Queries müssen client-seitig nach companyId filtern
    match /auditLogs {
      allow list: if isAdmin();
    }

    // Route Cache: Nur für Admin-Zugriff (Lesen) und System-Schreiben
    match /route_cache/{documentId} {
      allow read: if isAdmin();
      allow write: if isAuthenticated(); // Jeder authentifizierte User kann schreiben (für Caching)
    }

    // Default: deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

