##############################################
# Schichtklar - Production Environment Template  #
##############################################

# Dieses Template dient als Vorlage für `.env.production`.
# Es basiert auf `docs/PRODUCTION_ENVIRONMENT.md` und `docs/ENVIRONMENT_SETUP.md`.

# ============================================
# Firebase Configuration (Production)
# ============================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_production_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ============================================
# Firebase Emulator Configuration (Production)
# ============================================
# WICHTIG: In Production IMMER auf false!
NEXT_PUBLIC_USE_EMULATOR=false

# ============================================
# Application Configuration
# ============================================
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# ============================================
# Feature Flags - PRODUCTION
# ============================================
# WICHTIG: Mock-Features dürfen in Production NIE aktiv sein.
NEXT_PUBLIC_ENABLE_MOCK_AUTH=false
NEXT_PUBLIC_ENABLE_MOCK_DATA=false
NEXT_PUBLIC_ENABLE_REALTIME=true

# ============================================
# Legal/Impressum Configuration (REQUIRED)
# ============================================
NEXT_PUBLIC_COMPANY_NAME=AufAbruf GmbH
NEXT_PUBLIC_LEGAL_FORM=GmbH
NEXT_PUBLIC_COMPANY_STREET=Herner Straße 134
NEXT_PUBLIC_COMPANY_CITY=Herten
NEXT_PUBLIC_COMPANY_ZIP=45699
NEXT_PUBLIC_COMPANY_COUNTRY=Deutschland
NEXT_PUBLIC_COMPANY_EMAIL=info@aufabruf.eu
NEXT_PUBLIC_COMPANY_PHONE=02366 58 292 58
NEXT_PUBLIC_COMPANY_WEBSITE=www.aufabruf.eu

# Register Information
NEXT_PUBLIC_REGISTER_NUMBER=HRB 9754
NEXT_PUBLIC_REGISTER_COURT=Amtsgericht Recklinghausen
NEXT_PUBLIC_VAT_ID=DE369 553 099

# Responsible Person
NEXT_PUBLIC_RESPONSIBLE_NAME=Christian Zak
NEXT_PUBLIC_RESPONSIBLE_POSITION=Geschäftsführer

# ============================================
# Sentry Error Tracking (Recommended)
# ============================================
NEXT_PUBLIC_SENTRY_DSN=

# ============================================
# Firebase Admin (für API-Routen wie /api/invitations)
# ============================================
# Erforderlich für das Hosting-Backend (Next.js auf Cloud Functions).
# In Firebase Console: Projekt > Functions > Hosting-Backend-Function > Umgebungsvariablen,
# oder .env.production / .env.schichtklar (wird beim Deploy geladen).
# Service-Account-JSON als Base64: echo -n '{"type":"service_account",...}' | base64
# FIREBASE_ADMIN_CREDENTIALS_BASE64=
# Oder als JSON-String (Escaping beachten): FIREBASE_ADMIN_CREDENTIALS=

# ============================================
# Einladungs-E-Mails (Server-seitig)
# ============================================
# Option A: Resend (empfohlen) – gleiche Variable wie lokal
# RESEND_API_KEY=
# Option B: Firebase Function – URL + Secret
# FIREBASE_INVITATION_EMAIL_URL=https://us-central1-schichtklar.cloudfunctions.net/sendInvitationEmailHttp
# INVITATION_EMAIL_SECRET=


# ============================================
# Admin-Bootstrap (Erst-Einrichtung)
# ============================================
# Die Seite /fix-admin-role und die API /api/auth/ensure-admin-role sind in
# Produktion standardmäßig deaktiviert. Nur für die Erst-Einrichtung aktivieren
# und danach wieder entfernen:
# ENABLE_ADMIN_BOOTSTRAP=true
# ADMIN_BOOTSTRAP_EMAIL=admin@deine-firma.de
# NEXT_PUBLIC_ENABLE_ADMIN_BOOTSTRAP=true
