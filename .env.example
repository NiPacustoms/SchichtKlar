# ============================================
# JobFlow - Environment Variables Template
# ============================================
# Kopiere diese Datei zu .env.local und fülle die Werte aus
# WICHTIG: .env.local ist in .gitignore und wird nicht ins Repository committet

# ============================================
# Firebase Configuration (REQUIRED)
# ============================================
# Diese Werte findest du in der Firebase Console unter Project Settings > General
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ============================================
# Firebase Emulator Configuration (Development)
# ============================================
# Setze auf true für lokale Entwicklung mit Firebase Emulator
# WICHTIG: In Production IMMER auf false setzen!
NEXT_PUBLIC_USE_EMULATOR=false

# ============================================
# Application Configuration
# ============================================
# Environment: development, staging, production
NEXT_PUBLIC_APP_ENV=development
# Application URL (ohne trailing slash). Wichtig: Einladungs-Links in E-Mails nutzen diese URL.
# Lokal: http://localhost:3000. Für echte Einladungen: Ihre öffentliche URL (z. B. https://app.ihredomain.de).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# WebSocket Configuration (Optional)
# ============================================
# Für Realtime Updates (falls verwendet)
NEXT_PUBLIC_WS_URL=wss://your-websocket-server.com

# ============================================
# Feature Flags (Development)
# ============================================
# WICHTIG: In Production alle auf false setzen!
NEXT_PUBLIC_ENABLE_MOCK_AUTH=false
NEXT_PUBLIC_ENABLE_MOCK_DATA=false
NEXT_PUBLIC_ENABLE_REALTIME=true

# ============================================
# Legal/Impressum Configuration (REQUIRED for Production)
# ============================================
# Diese Werte MÜSSEN für Production gesetzt werden!
# Siehe auch: lib/config/legal.ts
NEXT_PUBLIC_COMPANY_NAME=AufAbruf GmbH
NEXT_PUBLIC_LEGAL_FORM=GmbH
NEXT_PUBLIC_COMPANY_STREET=Herner Straße 134
NEXT_PUBLIC_COMPANY_CITY=Herten
NEXT_PUBLIC_COMPANY_ZIP=45699
NEXT_PUBLIC_COMPANY_COUNTRY=Deutschland
NEXT_PUBLIC_COMPANY_EMAIL=info@aufabruf.eu
NEXT_PUBLIC_COMPANY_PHONE=02366 58 292 58
NEXT_PUBLIC_COMPANY_WEBSITE=www.aufabruf.eu

# Register Information
NEXT_PUBLIC_REGISTER_NUMBER=HRB 9754
NEXT_PUBLIC_REGISTER_COURT=Amtsgericht Recklinghausen
NEXT_PUBLIC_VAT_ID=DE369 553 099

# Responsible Person
NEXT_PUBLIC_RESPONSIBLE_NAME=Christian Zak
NEXT_PUBLIC_RESPONSIBLE_POSITION=Geschäftsführer

# ============================================
# Sentry Error Tracking (Optional but recommended)
# ============================================
# Für Production empfohlen: Error-Tracking aktivieren
# DSN findest du in Sentry unter Settings > Projects > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=

# ============================================
# Server-side Environment Variables (Optional)
# ============================================
# Diese Variablen sind nur auf dem Server verfügbar (nicht NEXT_PUBLIC_)
# Sie werden in API Routes und Server Components verwendet

# Firebase Admin SDK (für Server-side Operations)
# Wird automatisch aus Service Account JSON geladen (siehe lib/server/firebaseAdmin.ts)
# Alternativ können diese Variablen gesetzt werden:
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_CLIENT_EMAIL=your_service_account_email
# FIREBASE_PRIVATE_KEY=your_private_key

# Security Webhook (Optional)
# Für Security-Alerts und Monitoring
# SECURITY_WEBHOOK_URL=https://your-webhook-url.com

# ============================================
# E-Mail – Resend (PFLICHT für E-Mail-Versand)
# ============================================
# Alle E-Mails (Einladungen, Einsatzmitteilungen, Dokumente) werden über Resend versendet.
# API-Key: https://resend.com/api-keys (kostenlos bis 3000 E-Mails/Monat)
# WICHTIG: Ohne diesen Key werden keine E-Mails versendet!
RESEND_API_KEY=
# Absenderadresse (nach Domain-Verifizierung bei Resend eintragen):
RESEND_FROM=AufAbruf <noreply@aufabruf.eu>

# Einladungs-E-Mails: Legacy-Fallback via Firebase Cloud Function (nur wenn kein RESEND_API_KEY):
# FIREBASE_INVITATION_EMAIL_URL=https://us-central1-IHR_PROJEKT.cloudfunctions.net/sendInvitationEmailHttp
# INVITATION_EMAIL_SECRET=  (muss identisch mit functions/.env sein)

# ============================================
# Production Checklist
# ============================================
# Vor Production-Release prüfen:
# [ ] NEXT_PUBLIC_USE_EMULATOR=false
# [ ] NEXT_PUBLIC_ENABLE_MOCK_AUTH=false
# [ ] NEXT_PUBLIC_ENABLE_MOCK_DATA=false
# [ ] Alle NEXT_PUBLIC_COMPANY_* Variablen mit echten Firmendaten gefüllt
# [ ] NEXT_PUBLIC_SENTRY_DSN gesetzt (empfohlen)
# [ ] NEXT_PUBLIC_APP_ENV=production
# [ ] NEXT_PUBLIC_APP_URL mit Production-URL gesetzt
# [ ] RESEND_API_KEY gesetzt (für Einladungs-E-Mails)
