# npm Konfiguration für Schichtklar
# Verhindert Probleme mit Git-Worktrees

# Stelle sicher, dass node_modules lokal installiert werden
# (nicht als Symlink zu anderen Worktrees)
legacy-peer-deps=false

# Cache-Einstellungen
# Kein expliziter Cache-Pfad, damit Firebase Cloud Build den Standard-Cache verwendet

# Automatische Installation von Peer Dependencies
auto-install-peers=true

# Präferiere exakte Versionen aus package-lock.json
package-lock=true
